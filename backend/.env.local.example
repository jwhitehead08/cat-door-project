# ---------------------------------------------------------------
# Supabase
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Project Settings → API → service_role secret key (never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------
# Resend
# resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------
# Admin email — where lead notifications are sent
ADMIN_EMAIL=you@Digsy.com

# ---------------------------------------------------------------
# CORS — origin of the frontend app (used in next.config.ts)
# Production: https://Digsy.com
FRONTEND_ORIGIN=http://localhost:3000
